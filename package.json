{
  "name": "emberexchange",
  "version": "1.0.0",
  "description": "Ember Exchange Application",
  "main": "dist/backend/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/backend/app.js",
    "dev": "nodemon",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend:watch\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "frontend:build": "cd src/frontend && npx ng build",
    "frontend:serve": "cd src/frontend && npx ng serve",
    "frontend:watch": "cd src/frontend && npx ng build --watch --configuration development",
    "frontend:test": "cd src/frontend && npx ng test"
  },
  "dependencies": {
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "rxjs": "~7.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "http-status-codes": "^2.3.0",
    "jest": "^30.2.0",
    "jsdom": "^29.0.2",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.8"
  }
}
